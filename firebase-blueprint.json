
{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "monthly", "annual"] },
        "expiryDate": { "type": "string" },
        "isDev": { "type": "boolean" },
        "company": { "type": "string" },
        "role": { "type": "string" },
        "sector": { "type": "string" },
        "phone": { "type": "string" },
        "sentDocuments": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of documents already sent to the user (e.g., 'catalog', 'eafu')"
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents stored by their Firebase Auth UID"
    }
  }
}
