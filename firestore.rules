
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - plan: string (free, monthly, annual)
    //   - expiryDate: string (ISO date)
    //   - isDev: boolean
    //   - company: string
    //   - role: string
    //   - sector: string
    //   - phone: string
    //   - sentDocuments: list
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isDev == true ||
        (request.auth.token.email == "48mineiro@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('plan' in data) || data.plan in ['free', 'monthly', 'annual']) &&
             (!('isDev' in data) || data.isDev is bool) &&
             (!('sentDocuments' in data) || data.sentDocuments is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admins can read any profile.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile if it's marked as 'free' plan (unless admin)
      // and they can't set themselves as isDev unless they are already admin.
      allow create: if isOwner(userId) && 
                       isValidUser(request.resource.data) &&
                       (request.resource.data.plan == 'free' || isAdmin()) &&
                       (request.resource.data.isDev == false || isAdmin());
      
      // Users can update their own profile but cannot change their plan or isDev status
      // unless they are an admin.
      allow update: if isOwner(userId) && 
                       isValidUser(request.resource.data) &&
                       (request.resource.data.plan == resource.data.plan || isAdmin()) &&
                       (request.resource.data.isDev == resource.data.isDev || isAdmin());
                       
      // Only admins can delete users
      allow delete: if isAdmin();
    }
  }
}
